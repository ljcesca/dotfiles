#!/usr/bin/env bash

# Usage:
#   ./count_filetypes.sh [directory]
#
# Example:
#   ./count_filetypes.sh /data
#
# For each first-level subdirectory under the root,
# recursively counts file extensions for all contained files.

set -euo pipefail

ROOT_DIR="${1:-.}"

if [[ ! -d "$ROOT_DIR" ]]; then
	echo "Error: '$ROOT_DIR' is not a directory"
	exit 1
fi

for dir in "$ROOT_DIR"/*; do
	[[ -d "$dir" ]] || continue

	echo "Directory: $(basename "$dir")"

	find "$dir" -type f |
		awk '
    {
        file = $0
        sub(/^.*\//, "", file)

        if (file ~ /^\.[^.]+$/) {
            ext = "[no_extension]"
        } else if (file ~ /\./) {
            n = split(file, parts, ".")
            ext = tolower(parts[n])
        } else {
            ext = "[no_extension]"
        }

        count[ext]++
    }
    END {
        for (e in count) {
            printf "  %-20s %d\n", e, count[e]
        }
    }' | sort

	echo
done
